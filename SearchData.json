---
layout: null
---
[
  {%- assign documents = site.notes | concat: site.posts -%}
  {%- for document in documents -%}
    {
      "title": {{ document.title | jsonify }},
      "doc": {{ document.title | jsonify }},
      "content": {{ document.content | markdownify | strip_html | normalize_whitespace | jsonify }},
      "url": {{ document.url | relative_url | jsonify }}
    }{% unless forloop.last %},{% endunless %}
  {%- endfor -%}
]
